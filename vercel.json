{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://dattu-crm-backend.onrender.com/api/:path*"
    },
    {
      "source": "/ai/:path*",
      "destination": "https://dattu-crm-backend.onrender.com/ai/:path*"
    },
    {
      "source": "/alerts/:path*",
      "destination": "https://dattu-crm-backend.onrender.com/alerts/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://dattu-crm-backend.onrender.com/uploads/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
